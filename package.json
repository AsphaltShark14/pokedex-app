{
  "name": "pokedex-app",
  "main": "expo-router/entry",
  "version": "1.9.0",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "build:dev": "eas build --profile development",
    "build:preview": "eas build --profile preview",
    "build:prod": "eas build --profile production"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "\\.css$": "<rootDir>/jest/css-mock.js"
    }
  },
  "dependencies": {
    "@expo-google-fonts/press-start-2p": "^0.4.1",
    "@expo/ui": "~57.0.4",
    "@react-native/jest-preset": "^0.86.0",
    "@tamagui/babel-plugin": "^2.4.2",
    "@tamagui/config": "^2.4.2",
    "@tamagui/metro-plugin": "^2.4.2",
    "@tanstack/react-query": "^5.101.2",
    "expo": "~57.0.4",
    "expo-blur": "~57.0.0",
    "expo-constants": "~57.0.3",
    "expo-device": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-glass-effect": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-router": "~57.0.4",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "jest": "~29.7.0",
    "jest-expo": "~57.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "react-test-renderer": "19.2.3",
    "tamagui": "^2.4.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/react-native": "13.3.3",
    "@types/react": "~19.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~57.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.4",
    "typescript": "~6.0.3"
  }
}
